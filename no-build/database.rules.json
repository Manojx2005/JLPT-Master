{
  "rules": {
    // Default: deny everything. Each branch below opens up only what the app needs.
    ".read": false,
    ".write": false,

    // Seed data (vocabulary / grammar). Public to read, but only an
    // admin editing in the Firebase Console can write it (write stays false).
    "global_jlpt_vocab": {
      ".read": true,
      ".write": false
    },
    "global_grammar": {
      ".read": true,
      ".write": false
    },

    // Global leaderboard. Anyone can read the board, but a signed-in user
    // may only create/update their OWN row, and the payload is validated so
    // bots cannot inject huge strings or arbitrary fields.
    "leaderboard": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name'])",
        "name":   { ".validate": "newData.isString() && newData.val().length <= 40" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 8" },
        "xp":     { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000" },
        "score":  { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "$other": { ".validate": false }
      }
    },

    // Community-submitted dictionary words. Signed-in users can append; each
    // entry is shape-checked. Existing entries cannot be edited or deleted.
    "community_dictionary": {
      ".read": true,
      "$entryId": {
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['word'])",
        "word":    { ".validate": "newData.isString() && newData.val().length <= 80" },
        "reading": { ".validate": "newData.isString() && newData.val().length <= 80" },
        "meaning": { ".validate": "newData.isString() && newData.val().length <= 300" }
      }
    },

    // Multiplayer rooms. Any signed-in player can read/join/create a room.
    // Within a room, a player may only write their OWN player node, while
    // room-level fields (state, questions, host) stay editable for gameplay.
    "rooms": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null",
        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
