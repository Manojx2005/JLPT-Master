{
  "rules": {
    // Vocabulary and grammar data: public read, no client writes.
    "global_jlpt_vocab": {
      ".read": true,
      ".write": false
    },
    "global_grammar": {
      ".read": true,
      ".write": false
    },

    // Leaderboard: authenticated users can write their own score only.
    "leaderboard": {
      ".read": true,
      "$uid": {
        ".write": "auth !== null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name', 'score']) && newData.child('score').isNumber()"
      }
    },

    // community_dictionary is retired — block all access.
    "community_dictionary": {
      ".read": false,
      ".write": false
    },

    // Everything else is denied by default.
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
