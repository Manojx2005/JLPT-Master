{
  "rules": {
    "global_jlpt_vocab": {
      ".read": true,
      ".write": false
    },
    "global_grammar": {
      ".read": true,
      ".write": false
    },
    "leaderboard": {
      ".read": true,
      "$uid": {
        ".write": "auth !== null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name', 'xp']) && newData.child('xp').isNumber()"
      }
    },
    "user_data": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "app_reviews": {
      ".read": true,
      ".write": "auth !== null"
    },
    "rooms": {
      ".read": true,
      ".indexOn": [
        "state"
      ],
      "$code": {
        ".write": true
      }
    },
    "community_dictionary": {
      ".read": false,
      ".write": false
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}